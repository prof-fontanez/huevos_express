{
    "rewrites": [
        { 
            "source": "/((?!.*\\.(jpg|jpeg|png|gif|svg|ico|webp|js|css|json|txt|xml)).*)",
            "destination": "/index.html" 
        }
    ],
    "headers": [
        {
            "source": "/static/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        },
        {
            "source": "/(.*).(js|css)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        }
    ]
}