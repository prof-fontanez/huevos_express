{
    "rewrites": [
        { "source": "/", "destination": "/index.html" },
        { "source": "/product", "destination": "/index.html" },
        { "source": "/history", "destination": "/index.html" },
        { "source": "/heroes", "destination": "/index.html" },
        { "source": "/activities", "destination": "/index.html" },
        { "source": "/admin/products", "destination": "/index.html" },
        { "source": "/calendar", "destination": "/index.html" },
        { "source": "/thankyou", "destination": "/index.html" }
    ],
    "headers": [
        {
            "source": "/static/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        },
        {
            "source": "/(.*).(js|css)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        }
    ]
}